# Supabase - politiko
# Copie este arquivo para .env e preencha com suas credenciais
# Projeto em: https://supabase.com/dashboard

SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_ANON_KEY=eyJ...

# Conexão direta (não-IPv4)
DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# Session Pooler (IPv4-compatível)
DATABASE_URL_POOLER=postgresql://postgres.<project-ref>:<password>@aws-0-sa-east-1.pooler.supabase.com:5432/postgres

DB_PASSWORD=
